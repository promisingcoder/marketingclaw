{
  "name": "@marketingclaw/copilot",
  "version": "2026.6.11",
  "description": "MarketingClaw GitHub Copilot agent runtime plugin (registers a `github-copilot` AgentHarness backed by @github/copilot-sdk over JSON-RPC to the GitHub Copilot CLI)",
  "repository": {
    "type": "git",
    "url": "https://github.com/promisingcoder/marketingclaw"
  },
  "type": "module",
  "dependencies": {
    "@github/copilot-sdk": "1.0.5"
  },
  "devDependencies": {
    "@github/copilot": "1.0.68",
    "@marketingclaw/plugin-sdk": "workspace:*"
  },
  "marketingclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "clawhubSpec": "clawhub:@marketingclaw/copilot",
      "npmSpec": "@marketingclaw/copilot",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.28"
    },
    "compat": {
      "pluginApi": ">=2026.6.11"
    },
    "build": {
      "marketingclawVersion": "2026.6.11",
      "bundledDist": false
    },
    "release": {
      "bundleRuntimeDependencies": false,
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
