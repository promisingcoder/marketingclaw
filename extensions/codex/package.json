{
  "name": "@marketingclaw/codex",
  "version": "2026.6.11",
  "description": "MarketingClaw Codex app-server harness and model provider plugin with a Codex-managed GPT catalog.",
  "repository": {
    "type": "git",
    "url": "https://github.com/promisingcoder/marketingclaw"
  },
  "type": "module",
  "dependencies": {
    "@openai/codex": "0.143.0",
    "typebox": "1.3.3",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@marketingclaw/plugin-sdk": "workspace:*"
  },
  "marketingclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@marketingclaw/codex",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.1-beta.1",
      "requiredPlatformPackages": [
        "@openai/codex-linux-x64",
        "@openai/codex-linux-arm64",
        "@openai/codex-darwin-x64",
        "@openai/codex-darwin-arm64",
        "@openai/codex-win32-x64",
        "@openai/codex-win32-arm64"
      ]
    },
    "compat": {
      "pluginApi": ">=2026.6.11"
    },
    "build": {
      "marketingclawVersion": "2026.6.11"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true,
      "requireLatestDependencies": [
        "@openai/codex"
      ],
      "bundleRuntimeDependencies": false
    }
  }
}
