{
  "name": "@marketingclaw/raft",
  "version": "2026.6.11",
  "description": "MarketingClaw Raft channel plugin for Raft CLI wake bridges.",
  "repository": {
    "type": "git",
    "url": "https://github.com/promisingcoder/marketingclaw"
  },
  "type": "module",
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@marketingclaw/plugin-sdk": "workspace:*",
    "marketingclaw": "workspace:*"
  },
  "peerDependencies": {
    "marketingclaw": ">=2026.6.11"
  },
  "peerDependenciesMeta": {
    "marketingclaw": {
      "optional": true
    }
  },
  "marketingclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "install": {
      "npmSpec": "@marketingclaw/raft",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.6.8"
    },
    "compat": {
      "pluginApi": ">=2026.6.11"
    },
    "build": {
      "marketingclawVersion": "2026.6.11"
    },
    "channel": {
      "id": "raft",
      "label": "Raft",
      "selectionLabel": "Raft (CLI wake bridge)",
      "docsPath": "/channels/raft",
      "docsLabel": "raft",
      "blurb": "Raft CLI wake bridge for human and agent collaboration.",
      "order": 72
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
