{
  "name": "@marketingclaw/firecrawl-plugin",
  "version": "2026.6.11",
  "description": "MarketingClaw Firecrawl plugin.",
  "repository": {
    "type": "git",
    "url": "https://github.com/promisingcoder/marketingclaw"
  },
  "type": "module",
  "dependencies": {
    "typebox": "1.3.3"
  },
  "devDependencies": {
    "@marketingclaw/plugin-sdk": "workspace:*"
  },
  "marketingclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "clawhubSpec": "clawhub:@marketingclaw/firecrawl-plugin",
      "npmSpec": "@marketingclaw/firecrawl-plugin",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.6.8"
    },
    "compat": {
      "pluginApi": ">=2026.6.11"
    },
    "build": {
      "marketingclawVersion": "2026.6.11",
      "bundledDist": false
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
