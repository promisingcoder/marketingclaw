{
  "name": "@marketingclaw/diffs",
  "version": "2026.6.11",
  "description": "MarketingClaw read-only diff viewer plugin and file renderer for agents.",
  "repository": {
    "type": "git",
    "url": "https://github.com/promisingcoder/marketingclaw"
  },
  "type": "module",
  "dependencies": {
    "@pierre/diffs": "1.2.12",
    "@shikijs/langs": "4.3.0",
    "playwright-core": "1.61.1",
    "typebox": "1.3.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@marketingclaw/plugin-sdk": "workspace:*"
  },
  "marketingclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@marketingclaw/diffs",
      "localPath": "extensions/diffs",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.30"
    },
    "compat": {
      "pluginApi": ">=2026.6.11"
    },
    "assetScripts": {
      "build": "node ../../scripts/build-diffs-viewer-runtime.mjs curated"
    },
    "build": {
      "marketingclawVersion": "2026.6.11",
      "staticAssets": [
        {
          "source": "./assets/viewer-runtime.js",
          "output": "assets/viewer-runtime.js"
        }
      ]
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
