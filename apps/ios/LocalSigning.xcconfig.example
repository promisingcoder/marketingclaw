// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

MARKETINGCLAW_CODE_SIGN_STYLE = Automatic
MARKETINGCLAW_CODE_SIGN_IDENTITY = Apple Development
MARKETINGCLAW_DEVELOPMENT_TEAM = YOUR_TEAM_ID

MARKETINGCLAW_APP_BUNDLE_ID = ai.marketingclaw.app
MARKETINGCLAW_SHARE_BUNDLE_ID = ai.marketingclaw.app.share
MARKETINGCLAW_APP_GROUP_ID = group.ai.marketingclaw.app.shared
MARKETINGCLAW_ACTIVITY_WIDGET_BUNDLE_ID = ai.marketingclaw.app.activitywidget
MARKETINGCLAW_WATCH_APP_BUNDLE_ID = ai.marketingclaw.app.watchkitapp

// Leave empty with automatic signing.
MARKETINGCLAW_APP_PROFILE =
MARKETINGCLAW_SHARE_PROFILE =
MARKETINGCLAW_ACTIVITY_WIDGET_PROFILE =
MARKETINGCLAW_WATCH_APP_PROFILE =
