// Default signing values for shared/repo builds.
// Auto-selected local team overrides live in .local-signing.xcconfig (git-ignored).
// Manual local overrides can go in LocalSigning.xcconfig (git-ignored).

#include "build/Version.xcconfig"

MARKETINGCLAW_CODE_SIGN_STYLE = Manual
MARKETINGCLAW_CODE_SIGN_IDENTITY = Apple Development
MARKETINGCLAW_CODE_SIGN_ENTITLEMENTS = Sources/MarketingClaw.entitlements
MARKETINGCLAW_DEVELOPMENT_TEAM = FWJYW4S8P8

MARKETINGCLAW_APP_BUNDLE_ID = ai.marketingclaw.app
MARKETINGCLAW_SHARE_BUNDLE_ID = ai.marketingclaw.app.share
MARKETINGCLAW_APP_GROUP_ID = group.ai.marketingclaw.app.shared
MARKETINGCLAW_WATCH_APP_BUNDLE_ID = ai.marketingclaw.app.watchkitapp
MARKETINGCLAW_ACTIVITY_WIDGET_BUNDLE_ID = ai.marketingclaw.app.activitywidget
MARKETINGCLAW_APNS_ENTITLEMENT_ENVIRONMENT = development

MARKETINGCLAW_APP_PROFILE = ai.marketingclaw.app Development
MARKETINGCLAW_SHARE_PROFILE = ai.marketingclaw.app.share Development
MARKETINGCLAW_ACTIVITY_WIDGET_PROFILE =
MARKETINGCLAW_WATCH_APP_PROFILE =

// Keep local includes after defaults: xcconfig is evaluated top-to-bottom,
// so later assignments in local files override the defaults above.
#include? ".local-signing.xcconfig"
#include? "LocalSigning.xcconfig"

// Debug products install alongside release products and keep their app-group data separate.
MARKETINGCLAW_DEBUG_APP_BUNDLE_ID = $(MARKETINGCLAW_APP_BUNDLE_ID).debug
MARKETINGCLAW_DEBUG_SHARE_BUNDLE_ID = $(MARKETINGCLAW_DEBUG_APP_BUNDLE_ID).share
MARKETINGCLAW_DEBUG_ACTIVITY_WIDGET_BUNDLE_ID = $(MARKETINGCLAW_DEBUG_APP_BUNDLE_ID).activitywidget
MARKETINGCLAW_DEBUG_WATCH_APP_BUNDLE_ID = $(MARKETINGCLAW_DEBUG_APP_BUNDLE_ID).watchkitapp
MARKETINGCLAW_DEBUG_APP_GROUP_ID = $(MARKETINGCLAW_APP_GROUP_ID).debug
