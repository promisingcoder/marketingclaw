#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
RUN_NODE_TOOL="$ROOT_DIR/scripts/pre-commit/run-node-tool.sh"
FILTER_FILES="$ROOT_DIR/scripts/pre-commit/filter-staged-files.mjs"

if [[ ! -x "$RUN_NODE_TOOL" ]]; then
  echo "Missing helper: $RUN_NODE_TOOL" >&2
  exit 1
fi

if [[ ! -f "$FILTER_FILES" ]]; then
  echo "Missing helper: $FILTER_FILES" >&2
  exit 1
fi

GIT_DIR="$(git rev-parse --git-dir 2>/dev/null || true)"
if [[ -n "$GIT_DIR" ]] && \
  { [[ -f "$GIT_DIR/MERGE_HEAD" ]] || \
    [[ -f "$GIT_DIR/CHERRY_PICK_HEAD" ]] || \
    [[ -f "$GIT_DIR/REVERT_HEAD" ]] || \
    [[ -f "$GIT_DIR/REBASE_HEAD" ]] || \
    [[ -d "$GIT_DIR/rebase-merge" ]] || \
    [[ -d "$GIT_DIR/rebase-apply" ]]; }; then
  # Sequencer commits stage the operation result, not just the user's local edits.
  exit 0
fi

# Security: avoid option-injection from malicious file names (e.g. "--all", "--force").
# Robustness: NUL-delimited file list handles spaces/newlines safely.
# Compatibility: use read loops instead of `mapfile` so this runs on macOS Bash 3.x.
files=()
while IFS= read -r -d '' file; do
  files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if [ "${#files[@]}" -eq 0 ]; then
  exit 0
fi

restage_files=()
if [ "${BASH_VERSINFO[0]:-0}" -ge 4 ]; then
  # Fast path: one `git check-ignore --stdin` call plus a hash lookup, instead of
  # one process per file. A per-file loop is prohibitively slow on very large
  # commits (a fork-wide rename stages thousands of files). NUL-delimited I/O keeps
  # spaces/newlines in paths safe; requires associative arrays (Bash 4+).
  declare -A _ignored=()
  while IFS= read -r -d '' file; do
    _ignored["$file"]=1
  done < <(printf '%s\0' "${files[@]}" | git check-ignore --no-index --stdin -z 2>/dev/null)
  for file in "${files[@]}"; do
    if [ -z "${_ignored["$file"]+x}" ]; then
      restage_files+=("$file")
    fi
  done
  unset _ignored
else
  # Portable fallback (e.g. macOS Bash 3.2): one check-ignore per file.
  for file in "${files[@]}"; do
    if ! git check-ignore --no-index -q -- "$file"; then
      restage_files+=("$file")
    fi
  done
fi

# Batch the file lists through `xargs -0` so very large commits (e.g. a fork-wide
# rename touching thousands of files) don't blow the OS command-line length limit
# ("Argument list too long", ~32 KB on Windows). This does not skip any file:
# xargs chunks the same list and invokes the tool once per chunk.
format_files=()
if [ "${#restage_files[@]}" -gt 0 ]; then
  while IFS= read -r -d '' file; do
    format_files+=("$file")
  done < <(printf '%s\0' "${restage_files[@]}" | xargs -0 -r node "$FILTER_FILES" format --)
fi

if [ "${#format_files[@]}" -gt 0 ]; then
  printf '%s\0' "${format_files[@]}" | xargs -0 -r "$RUN_NODE_TOOL" oxfmt --write --no-error-on-unmatched-pattern
fi

if [ "${#restage_files[@]}" -gt 0 ]; then
  printf '%s\0' "${restage_files[@]}" | xargs -0 -r git add --
fi
