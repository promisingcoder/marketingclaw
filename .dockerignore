marketingclaw-path-alias-*

# build artifacts
dist
**/dist
apps/macos/.build
apps/ios/build
**/*.trace

# large app trees not needed for CLI build
apps/
vendor/

# Needed for building the Canvas A2UI bundle during Docker image builds.
# Keep the rest of apps/ and vendor/ excluded to avoid a large build context.
!apps/shared/
!apps/shared/MarketingClawKit/
!apps/shared/MarketingClawKit/Sources/
!apps/shared/MarketingClawKit/Sources/MarketingClawKit/
!apps/shared/MarketingClawKit/Sources/MarketingClawKit/Resources/
!apps/shared/MarketingClawKit/Sources/MarketingClawKit/Resources/tool-display.json
!apps/shared/MarketingClawKit/Tools/
!apps/shared/MarketingClawKit/Tools/CanvasA2UI/
!apps/shared/MarketingClawKit/Tools/CanvasA2UI/**
!vendor/a2ui/
!vendor/a2ui/renderers/
!vendor/a2ui/renderers/lit/
!vendor/a2ui/renderers/lit/**
