.git
.worktrees

# Sensitive files – scripts/docker/setup.sh writes .env with MARKETINGCLAW_GATEWAY_TOKEN
# into the project root; keep it out of the build context.
.env
.env.*

.bun-cache
.bun
.artifacts
**/.artifacts
.local
**/.local
.pi
**/.pi
__marketingclaw_vitest__
**/__marketingclaw_vitest__
.tmp
**/.tmp
.DS_Store
**/.DS_Store
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.mp4
*.mov
*.wav
*.mp3
node_modules
**/node_modules
